<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI Teacher | Flashcards</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Space+Grotesk:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body data-page="flashcards">
    <div class="background-shape"></div>
    <div class="background-shape two"></div>

    <%- include("partials/header") %>

    <main class="app-layout">
      <section class="hero-card">
        <p class="eyebrow">Flashcards</p>
        <h2>
          <span id="flashcard-count">0</span> cards ready for
          <span data-student-name>Student</span>
        </h2>
        <p>
          Build a stronger deck with tags, difficulty levels, spaced review,
          and quick editing.
        </p>
      </section>

      <section class="study-panel split-grid">
        <article class="panel-card">
          <div class="panel-header">
            <h2 id="flashcard-form-title">Add Flashcard</h2>
            <button
              class="ghost-btn hidden"
              id="flashcard-cancel-edit"
              type="button"
            >
              Cancel Edit
            </button>
          </div>
          <form id="flashcard-form" class="stack-form">
            <label for="card-topic">Topic</label>
            <input
              id="card-topic"
              name="topic"
              placeholder="Biology"
              required
            />
            <label for="card-question">Question</label>
            <textarea
              id="card-question"
              name="question"
              rows="3"
              placeholder="What is mitosis?"
              required
            ></textarea>
            <label for="card-answer">Answer</label>
            <textarea
              id="card-answer"
              name="answer"
              rows="3"
              placeholder="Mitosis is cell division..."
              required
            ></textarea>
            <label for="card-difficulty">Difficulty</label>
            <select id="card-difficulty" name="difficulty">
              <option value="easy">Easy</option>
              <option value="medium" selected>Medium</option>
              <option value="hard">Hard</option>
            </select>
            <label for="card-tags">Tags</label>
            <input
              id="card-tags"
              name="tags"
              placeholder="exam, chapter 3, review"
            />
            <button class="primary-btn" type="submit">Save Flashcard</button>
          </form>
          <p id="flashcard-status" class="status-text"></p>
        </article>

        <article class="panel-card">
          <div class="panel-header">
            <h2>Your Deck</h2>
          </div>
          <div class="control-row">
            <input
              id="flashcard-search"
              class="inline-search"
              placeholder="Search topic, question, answer, or tag"
            />
            <select id="flashcard-filter-difficulty">
              <option value="all">All difficulties</option>
              <option value="easy">Easy</option>
              <option value="medium">Medium</option>
              <option value="hard">Hard</option>
            </select>
            <select id="flashcard-sort">
              <option value="newest">Newest</option>
              <option value="oldest">Oldest</option>
              <option value="due">Due first</option>
              <option value="mastery-low">Lowest mastery</option>
              <option value="mastery-high">Highest mastery</option>
            </select>
          </div>
          <label class="toggle-row compact-toggle" for="flashcard-due-only">
            <span>Show due cards only</span>
            <input id="flashcard-due-only" type="checkbox" />
          </label>
          <div id="flashcard-list" class="flashcard-list"></div>
        </article>
      </section>
    </main>

    <script src="/app.js"></script>
  </body>
</html>
