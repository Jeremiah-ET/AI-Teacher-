<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI Teacher</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Space+Grotesk:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body data-page="dashboard">
    <%- include("partials/header") %>
    <div class="background-shape"></div>
    <div class="background-shape two"></div>

    <main class="app-layout">
      <section class="hero-card">
        <p class="eyebrow">Today</p>
        <h2>Welcome back, <span data-student-name>Student</span>.</h2>
        <p>
          Keep your streak alive by reviewing cards, practicing recall, and
          checking your progress.
        </p>
        <div class="hero-actions">
          <a class="primary-btn button-link" href="/practice"
            >Continue Practice</a
          >
          <a class="ghost-btn button-link" href="/flashcards"
            >Create Flashcards</a
          >
        </div>
      </section>

      <section class="stats-grid">
        <article class="stat-card">
          <p>Study Streak</p>
          <h3 id="dashboard-streak">0 days</h3>
        </article>
        <article class="stat-card">
          <p>Total Cards</p>
          <h3 id="dashboard-cards">0</h3>
        </article>
        <article class="stat-card">
          <p>Quiz Accuracy</p>
          <h3 id="dashboard-accuracy">0%</h3>
        </article>
        <article class="stat-card">
          <p>Level</p>
          <h3 id="dashboard-level">Lv. 1</h3>
        </article>
      </section>

      <section class="study-panel split-grid">
        <article class="panel-card">
          <div class="panel-header">
            <h2>Learning Snapshot</h2>
            <a class="ghost-btn button-link" href="/profile">Edit Profile</a>
          </div>
          <div id="dashboard-profile-summary" class="metric-list"></div>
        </article>

        <article class="panel-card">
          <h2>Topic Breakdown</h2>
          <div id="dashboard-topic-list" class="metric-list"></div>
        </article>
      </section>

      <section class="study-panel split-grid">
        <article class="panel-card">
          <h2>Smart Review</h2>
          <div id="dashboard-review-summary" class="metric-list"></div>
        </article>

        <article class="panel-card">
          <h2>Achievements</h2>
          <div id="dashboard-achievement-list" class="badge-list"></div>
        </article>
      </section>

      <section class="study-panel">
        <div class="panel-header">
          <h2>Recent Sessions</h2>
          <a class="ghost-btn button-link" href="/progress">View All</a>
        </div>
        <div id="dashboard-session-list" class="metric-list"></div>
      </section>
    </main>

    <script src="/app.js"></script>
  </body>
</html>
