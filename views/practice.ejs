<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI Teacher | Practice</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Space+Grotesk:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body data-page="practice">
    <div class="background-shape"></div>
    <div class="background-shape two"></div>

    <%- include("partials/header") %>

    <main class="app-layout">
      <section class="hero-card">
        <p class="eyebrow">Practice Session</p>
        <h2>Train recall with smarter review modes.</h2>
        <p>
          Current deck size: <strong id="practice-total-cards">0</strong> cards.
          Due cards, hard-card drills, multiple choice, and typed recall are
          all supported.
        </p>
      </section>

      <section id="practice-empty" class="study-panel hidden">
        <h2>No cards yet</h2>
        <p>
          Add cards on the Flashcards page, then come back to start practice.
        </p>
        <a class="primary-btn button-link" href="/flashcards"
          >Go to Flashcards</a
        >
      </section>

      <section id="practice-setup" class="study-panel">
        <div class="panel-header">
          <h2>Session Setup</h2>
        </div>
        <form id="practice-setup-form" class="stack-form practice-setup-grid">
          <p class="form-section-title">Question Count</p>
          <input
            id="practice-question-count"
            aria-label="Questions this round"
            type="number"
            min="1"
            max="25"
            step="1"
            value="5"
          />
          <p class="form-section-title">Mode</p>
          <select id="practice-mode" aria-label="Practice mode">
            <option value="flashcard">Flip Flashcards</option>
            <option value="written">Written Recall</option>
            <option value="multiple-choice">Multiple Choice</option>
            <option value="true-false">True / False</option>
            <option value="boss-battle">Boss Battle</option>
          </select>
          <p class="form-section-title">Topic</p>
          <select id="practice-topic-filter" aria-label="Topic focus">
            <option value="all">All topics</option>
          </select>
          <p class="form-section-title">Filters</p>
          <label class="toggle-row compact-toggle" for="practice-due-only">
            <span>Use due cards first</span>
            <input id="practice-due-only" type="checkbox" />
          </label>
          <label class="toggle-row compact-toggle" for="practice-hard-only">
            <span>Hard cards only</span>
            <input id="practice-hard-only" type="checkbox" />
          </label>
          <label class="toggle-row compact-toggle" for="practice-random-order">
            <span>Shuffle card order</span>
            <input id="practice-random-order" type="checkbox" checked />
          </label>
          <button class="primary-btn" id="practice-start" type="submit">
            Start Practice
          </button>
        </form>
      </section>

      <section id="practice-run" class="study-panel hidden">
        <div class="panel-header">
          <h2 id="practice-progress">Question 1 of 5</h2>
        </div>
        <article class="panel-card">
          <div class="practice-card-meta">
            <span id="practice-topic-pill" class="pill">General</span>
            <span id="practice-mode-pill" class="pill subtle">Written Recall</span>
          </div>
          <p class="form-section-title">Question Prompt</p>
          <h3 id="practice-question"></h3>
          <p id="practice-prompt" class="muted"></p>
          <section id="practice-flashcard-mode" class="hidden">
            <div id="practice-flashcard" class="study-flip-card" aria-live="polite">
              <div class="study-flip-card-inner">
                <div class="study-flip-face study-flip-front">
                  <p class="eyebrow">Front</p>
                  <h3 id="practice-flashcard-front"></h3>
                  <p id="practice-flashcard-hint" class="muted"></p>
                </div>
                <div class="study-flip-face study-flip-back">
                  <p class="eyebrow">Back</p>
                  <h3 id="practice-flashcard-back"></h3>
                  <p id="practice-flashcard-topic" class="muted"></p>
                </div>
              </div>
            </div>
            <div class="hero-actions practice-flashcard-actions">
              <button class="ghost-btn" id="practice-flip" type="button">
                Flip Card
              </button>
              <button class="danger-btn hidden" id="practice-mark-wrong" type="button">
                I Missed It
              </button>
              <button class="primary-btn hidden" id="practice-mark-right" type="button">
                I Got It
              </button>
              <button class="ghost-btn hidden" id="practice-flashcard-next" type="button">
                Next Card
              </button>
            </div>
          </section>
          <form id="practice-answer-form" class="stack-form">
            <div id="practice-written-area">
              <label for="practice-answer">Your answer</label>
              <textarea id="practice-answer" rows="4"></textarea>
            </div>
            <div id="practice-options" class="options-grid hidden"></div>
            <button class="primary-btn" id="practice-submit" type="submit">
              Check Answer
            </button>
            <button
              class="ghost-btn hidden"
              id="practice-override-correct"
              type="button"
            >
              Override: I Was Right
            </button>
            <button class="ghost-btn hidden" id="practice-next" type="button">
              Next
            </button>
          </form>
          <p id="practice-feedback" class="status-text"></p>
        </article>
      </section>

      <section id="practice-result" class="study-panel hidden">
        <h2>Session Complete</h2>
        <p>
          Score: <strong id="practice-result-score">0%</strong> | Correct:
          <strong id="practice-result-correct">0</strong> /
          <strong id="practice-result-total">0</strong>
        </p>
        <p>
          XP earned: <strong id="practice-result-xp">0</strong> | Mode:
          <strong id="practice-result-mode">Written Recall</strong>
        </p>
        <p>
          Confidence: <strong id="practice-result-confidence">0%</strong> |
          Reviewed: <strong id="practice-result-reviewed">0</strong>
        </p>
        <div id="practice-result-missed" class="metric-list"></div>
        <div class="hero-actions">
          <button class="primary-btn" id="practice-restart" type="button">
            Practice Again
          </button>
          <a class="ghost-btn button-link" href="/progress"
            >See Progress</a
          >
        </div>
      </section>
    </main>

    <script src="/app.js"></script>
  </body>
</html>
